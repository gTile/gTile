{
  "name": "gnome-shell-extension-gtile",
  "type": "module",
  "version": "1.0.0",
  "description": "gTile Gnome extension",
  "module": "dist/extension.js",
  "author": "Markus Schanz <markus@schanz.id>",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@girs/adw-1": "^1.10.0-4.0.0-rc.1",
    "@girs/clutter-18": "^18.0.0-4.0.0-rc.1",
    "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.1",
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gjs": "^4.0.0-rc.1",
    "@girs/glib-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gnome-shell": "^50.0.0-alpha.1",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.1",
    "@girs/meta-18": "^18.0.0-4.0.0-rc.1",
    "@girs/mtk-18": "^18.0.0-4.0.0-rc.1",
    "@girs/pango-1.0": "^1.57.1-4.0.0-rc.1",
    "@girs/shell-18": "^18.0.0-4.0.0-rc.1",
    "@girs/st-18": "^18.0.0-4.0.0-rc.1",
    "ava": "^7.0.0",
    "typescript": "^6.0.2"
  },
  "ava": {
    "typescript": {
      "rewritePaths": {
        "src/": "out/src/",
        "test/": "out/test/"
      },
      "compile": false
    }
  },
  "scripts": {
    "clean": "git clean -qxf ':/dist' ':/out' gtile.dist.tgz",
    "prebuild": "$npm_execpath run clean",
    "build": "tsc -p tsconfig.prod.json",
    "postbuild": "rm -rf dist/types",
    "prebuild:dist": "$npm_execpath run build",
    "build:dist": "tar -czf gtile.dist.tgz -C dist .",
    "install:extension": "gnome-extensions install -f gtile.dist.tgz",
    "pretest": "tsc",
    "test": "ava",
    "check": "tsc --noEmit"
  }
}
